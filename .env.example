# Supabase Configuration
# Obtén estos valores desde: Supabase Dashboard → Settings → API

# URL del proyecto Supabase (ej: https://xxxx.supabase.co)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave pública anónima (NOT the service_role key)
# Obtén la "anon public" key, no la "service_role"
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Instrucciones:
# 1. Copia este archivo y renómbralo a .env.local
# 2. Reemplaza los valores con los de tu proyecto Supabase
# 3. NUNCA comitas .env.local — está en .gitignore
